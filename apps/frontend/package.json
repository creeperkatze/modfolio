{
  "name": "modfolio-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "intl:extract": "formatjs extract \"src/**/*.{vue,ts}\" --ignore \"src/**/*.d.ts\" --out-file src/locales/en-US/index.json --format crowdin --preserve-whitespace",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@lucide/vue": "^1.14.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@formatjs/cli": "^6.2.12",
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-vue": "^5.2.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.3.1",
    "vite-svg-loader": "^5.1.1",
    "vue-tsc": "^3.2.7"
  }
}
