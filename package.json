{
    "name": "modfolio",
    "version": "1.2.3",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
    "author": "Creeperkatze",
    "license": "AGPL-3.0-only",
    "scripts": {
        "dev": "concurrently -n backend,frontend -c blue,green \"pnpm --filter ./apps/backend dev\" \"pnpm --filter ./apps/frontend dev\"",
        "frontend:dev": "pnpm --filter ./apps/frontend dev",
        "frontend:build": "pnpm --filter ./apps/frontend build",
        "frontend:intl:extract": "pnpm --filter ./apps/frontend intl:extract",
        "backend:dev": "pnpm --filter ./apps/backend dev",
        "backend:build": "pnpm --filter ./apps/backend build",
        "backend:start": "pnpm --filter ./apps/backend start",
        "test": "pnpm -r test",
        "lint": "pnpm -r lint",
        "lint:fix": "pnpm -r lint:fix",
        "release:patch": "pnpm version patch && git push && git push --tags",
        "release:minor": "pnpm version minor && git push && git push --tags",
        "release:major": "pnpm version major && git push && git push --tags"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}
