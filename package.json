{
    "name": "modfolio",
    "version": "1.2.3",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
    "author": "Creeperkatze",
    "license": "AGPL-3.0-only",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "web:dev": "turbo run dev --filter=modfolio-web",
        "web:build": "turbo run build --filter=modfolio-web",
        "web:intl:extract": "pnpm --filter modfolio-web intl:extract",
        "api:dev": "turbo run dev --filter=modfolio-api",
        "api:build": "turbo run build --filter=modfolio-api",
        "api:start": "pnpm --filter modfolio-api start",
        "docs:dev": "turbo run dev --filter=modfolio-docs",
        "docs:build": "turbo run build --filter=modfolio-docs",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "lint:fix": "turbo run lint:fix",
        "release:patch": "pnpm version patch && git push && git push --tags",
        "release:minor": "pnpm version minor && git push && git push --tags",
        "release:major": "pnpm version major && git push && git push --tags"
    },
    "devDependencies": {
        "turbo": "^2.10.2"
    }
}
