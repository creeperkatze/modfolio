{
	"name": "modfolio",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.27.0",
	"author": "Creeperkatze",
	"license": "AGPL-3.0-only",
	"scripts": {
		"dev": "concurrently -n backend,frontend -c blue,green \"pnpm --filter ./apps/backend dev\" \"pnpm --filter ./apps/frontend dev\"",
		"frontend:dev": "pnpm --filter ./apps/frontend dev",
		"frontend:build": "pnpm --filter ./apps/frontend build",
		"backend:dev": "pnpm --filter ./apps/backend dev",
		"backend:start": "pnpm --filter ./apps/backend start",
		"lint": "pnpm -r lint",
		"lint:fix": "pnpm -r lint:fix"
	},
	"devDependencies": {
		"concurrently": "^9.2.1"
	}
}
